# URL publique du site (canonical, Open Graph, sitemap). En prod : domaine final sans slash final.
# Ex. https://portfolio.example.com — en local, localhost est utilisé si cette variable est vide.
NEXT_PUBLIC_SITE_URL=

# EmailJS — formulaire contact (https://www.emailjs.com/)
# Créer un compte, un service, un template, puis autoriser localhost + le domaine prod dans Security.
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
