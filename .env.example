# URL publique du site (canonical, Open Graph, sitemap). Sans slash final.
# Prod Vercel : https://davinchat-folio.vercel.app (déjà dans vercel.json — utile en local pour tester le build prod)
NEXT_PUBLIC_SITE_URL=https://davinchat-folio.vercel.app

# EmailJS — formulaire contact (https://www.emailjs.com/)
# Créer un compte, un service, un template, puis autoriser localhost + le domaine prod dans Security.
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
